{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "G-OpenSteamTool",
  "version": "0.2.3",
  "identifier": "com.gopensteamtool.manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "G-OpenSteamTool",
        "width": 1380,
        "height": 860,
        "minWidth": 1380,
        "minHeight": 860,
        "maxWidth": 1380,
        "maxHeight": 860,
        "resizable": false,
        "decorations": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "createUpdaterArtifacts": true,
    "resources": ["resources/dlls/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1RkVEOEVBN0VGRENENzYKUldSMnpmMSs2dGorMVZWQk5sZHc4UlhGblVmdWgxbG9QckRTVVpFUEloc1JlaWZ3QzBFNXVPK3AK",
      "endpoints": [
        "https://github.com/G-Yoka/G-OpenSteamTool/releases/latest/download/latest.json"
      ]
    }
  }
}
